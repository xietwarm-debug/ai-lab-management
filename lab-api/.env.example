# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=change_me
DB_NAME=lab_mgmt
DB_CHARSET=utf8mb4

# App runtime
APP_HOST=0.0.0.0
APP_PORT=5000
FLASK_DEBUG=1

# Auth
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRE_SECONDS=3600
REFRESH_EXPIRE_SECONDS=1209600

# Legacy password migration mode: username | 123456
LEGACY_DEFAULT_PASSWORD_MODE=username

# Reservation rules
RESERVATION_MIN_DAYS_AHEAD=0
RESERVATION_MAX_DAYS_AHEAD=30
RESERVATION_MIN_TIME=08:00
RESERVATION_MAX_TIME=22:00
RESERVATION_LOCK_TIMEOUT_SECONDS=5

# SiliconFlow Agent
SILICONFLOW_API_KEY=
SILICONFLOW_BASE_URL=https://api.siliconflow.cn
SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3
SILICONFLOW_TIMEOUT_SECONDS=20

# Tavily web search
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_TIMEOUT_SECONDS=15
AGENT_WEB_SEARCH_MAX_RESULTS=5

# Weather lookup
OPEN_METEO_GEOCODING_BASE_URL=https://geocoding-api.open-meteo.com
OPEN_METEO_FORECAST_BASE_URL=https://api.open-meteo.com
OPEN_METEO_TIMEOUT_SECONDS=12
